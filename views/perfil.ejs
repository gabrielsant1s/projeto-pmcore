<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Meu Perfil - PMcore</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/perfil.css">
</head>
<body>

    <%- include('partials/header') %>

    <main>
        <div class="perfil-container">
            <div class="perfil-header">
                <div class="avatar-grande">
                    <%= usuario.nome.charAt(0).toUpperCase() %>
                </div>
                <h1><%= usuario.nome %></h1>
                <p>Membro desde 2026</p>
            </div>

            <div class="perfil-body">
                <div class="info-group">
                    <div class="info-label">E-mail de Acesso</div>
                    <div class="info-value"><%= usuario.email %></div>
                </div>

                <div class="info-group">
                    <div class="info-label">Status da Conta</div>
                    <div class="info-value">
                        <span class="badge-plano">Ativo - Plano Pro</span>
                    </div>
                </div>

                <div style="display: flex; gap: 15px; margin-top: 30px;">
                    <a href="/logout" class="btn-primary" style="background-color: #ef4444; text-decoration: none; text-align: center;">Sair da Conta</a>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

</body>
</html>